{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020","dom"],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,

    "strict": true,
    "noImplicitAny": true,

    "types": ["node", "@playwright/test"],

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "./dist"
  },

  "include": ["src/**/*.ts", "config/**/*.ts"]
}